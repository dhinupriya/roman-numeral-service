{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Log Volume (logs/min)",
      "type": "barchart",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({compose_service=~\".+\"} [1m])) by (compose_service)",
          "legendFormat": "{{ compose_service }}",
          "refId": "A"
        }
      ],
      "options": {
        "stacking": "normal"
      }
    },
    {
      "title": "Error & Warning Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{compose_service=~\".+\"} |~ \"\\\"level\\\":\\\"(ERROR|WARN)\\\"\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "dedupStrategy": "none"
      }
    },
    {
      "title": "Application Logs (roman-numeral-service)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{compose_service=\"roman-numeral-service\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "dedupStrategy": "none"
      }
    },
    {
      "title": "Slow Requests (> 50ms)",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{compose_service=\"roman-numeral-service\"} |~ \"[0-9]{2,}ms\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    },
    {
      "title": "401 Unauthorized Requests",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{compose_service=\"roman-numeral-service\"} |~ \"→ 401|Missing API key|Invalid API key\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    },
    {
      "title": "429 Rate Limited Requests",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{compose_service=\"roman-numeral-service\"} |~ \"→ 429|Rate limit exceeded\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["roman-numeral", "logs"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
