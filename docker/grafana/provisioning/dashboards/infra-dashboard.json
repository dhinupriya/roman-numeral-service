{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Container CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\".+\"}[1m])",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit" }
      }
    },
    {
      "title": "Container Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\".+\"}",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Network I/O (All Containers)",
      "description": "Aggregate network throughput. Per-container breakdown available on Linux; Docker Desktop aggregates network metrics.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{interface!=\"\"}[1m]))",
          "legendFormat": "Receive (RX)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{interface!=\"\"}[1m]))",
          "legendFormat": "Transmit (TX)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Host CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m]))",
          "legendFormat": "CPU Usage %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1 }
      }
    },
    {
      "title": "Host Memory Usage",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "Used",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1 }
      }
    },
    {
      "title": "Host Disk Usage",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "1 - (node_filesystem_avail_bytes{device=~\"/dev/.+\"} / node_filesystem_size_bytes{device=~\"/dev/.+\"})",
          "legendFormat": "Used",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1 }
      }
    },
    {
      "title": "Container Count & Uptime",
      "description": "Number of running containers and how long each has been running.",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "time() - container_start_time_seconds{name=~\"roman-numeral.*\"}",
          "legendFormat": "{{ name }}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": [
          { "matcher": {"id": "byName", "options": "Time"}, "properties": [{"id": "custom.hidden", "value": true}] },
          { "matcher": {"id": "byName", "options": "__name__"}, "properties": [{"id": "custom.hidden", "value": true}] },
          { "matcher": {"id": "byName", "options": "instance"}, "properties": [{"id": "custom.hidden", "value": true}] },
          { "matcher": {"id": "byName", "options": "job"}, "properties": [{"id": "custom.hidden", "value": true}] },
          { "matcher": {"id": "byName", "options": "id"}, "properties": [{"id": "custom.hidden", "value": true}] }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Value", "desc": true }]
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["roman-numeral", "infrastructure"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Roman Numeral Service — Infrastructure Dashboard",
  "uid": "roman-numeral-infra",
  "version": 2
}
